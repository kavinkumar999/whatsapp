# Copy to `service/.env` and fill in real values (`.env` is gitignored).
# Used by `npm run link` and by `node service/src/send.js` (run send from repo root).

UPSTASH_REDIS_REST_URL=https://YOUR-INSTANCE.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN

# For local sends: either set MESSAGE, or rotate from Upstash (same keys as CI schedule).
# MESSAGE=Hello {{name}} — test from local.
# MESSAGE_SOURCE=redis

# Optional — Baileys session snapshot in Redis (default wa:auth_info). `npm run auth:clear` deletes it.
# UPSTASH_AUTH_KEY=wa:auth_info

# Optional — Redis JSON keys for the quote list and cursor (defaults: wa:quotes, wa:quotes:cursor)
# UPSTASH_QUOTES_KEY=wa:quotes
# UPSTASH_QUOTES_CURSOR_KEY=wa:quotes:cursor
