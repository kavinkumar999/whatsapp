# Copy to `service/.env` and fill in real values (`.env` is gitignored).
# Used by `npm run link` and by `node service/src/send.js` (run send from repo root).

UPSTASH_REDIS_REST_URL=https://YOUR-INSTANCE.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN

# Optional for `npm run link`. Omit for QR in the terminal (default).
# If set: pairing-code flow instead — same account you are linking, digits only, no + or spaces.
# PHONE_NUMBER=919876543210

# For local sends (`node service/src/send.js` from repo root)
MESSAGE=Hello {{name}} — test from local.
