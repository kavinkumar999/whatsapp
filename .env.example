# Copy to `.env` and fill in real values (`.env` is gitignored).
# Loaded automatically by every command, from the repo root or a subdirectory.

# --- Required: Upstash Redis REST credentials (NOT the redis:// URL) ---
UPSTASH_REDIS_REST_URL=https://YOUR-INSTANCE.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN

# --- Message source for local sends (CI sets these itself) ---
# Either set a literal message...
# MESSAGE=Hello {{name}} — test from local.
# ...or rotate through the seeded quote list in Upstash:
# MESSAGE_SOURCE=redis

# --- Optional tuning ---
# Throttle between messages (anti-ban); defaults 5000 / 30000.
# MIN_DELAY_MS=5000
# MAX_DELAY_MS=30000

# Path to the recipients file (defaults to recipients.json in cwd or repo root).
# RECIPIENTS_FILE=recipients.json

# --- Optional: override the Redis keys (defaults shown) ---
# UPSTASH_AUTH_KEY=wa:auth_info
# UPSTASH_QUOTES_KEY=wa:quotes
# UPSTASH_QUOTES_CURSOR_KEY=wa:quotes:cursor
