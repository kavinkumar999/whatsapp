# Copy to `.env` and fill in real values (`.env` is gitignored).
# Loaded automatically by every command, from the repo root or a subdirectory.

# --- Required: Upstash Redis REST credentials (NOT the redis:// URL) ---
UPSTASH_REDIS_REST_URL=https://YOUR-INSTANCE.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN

# Both the messages and the recipients live in Upstash. Edit the lists in
# src/data/messages.js and src/data/recipients.js, then push them with
# `npm run messages:seed` and `npm run recipients:seed`. There is no MESSAGE env
# var: each send uses the message at the current cursor and advances it afterward.

# --- Optional tuning ---
# Throttle between messages (anti-ban); defaults 5000 / 30000.
# MIN_DELAY_MS=5000
# MAX_DELAY_MS=30000

# --- Optional: override the Redis keys (defaults shown) ---
# UPSTASH_AUTH_KEY=wa:auth_info
# UPSTASH_MESSAGES_KEY=wa:messages
# UPSTASH_MESSAGES_CURSOR_KEY=wa:messages:cursor
# UPSTASH_RECIPIENTS_KEY=wa:recipients
